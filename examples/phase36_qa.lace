let x = List.filter([1, 2, 3, 4], fn(n) { n > 2 })
assert_eq(x, [3, 4])
let y = Str.split("hello world", " ")
assert_eq(List.length(y), 2)
let z = List.map([1, 2, 3], fn(n) { n * 2 })
assert_eq(z, [2, 4, 6])
let s = Str.to_upper("hello")
assert_eq(s, "HELLO")
let nums = List.range(1, 5)
assert_eq(List.length(nums), 4)
let total = List.sum([10, 20, 30])
assert_eq(total, 60)
println("Phase 36 QA passed!")
