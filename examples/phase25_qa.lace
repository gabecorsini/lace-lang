fn apply(f: Fn, x: Int) -> Int [Pure] {
    f(x)
}

fn make_adder(n: Int) -> Fn [Pure] {
    fn(x) { x + n }
}

fn main() -> Unit [IO] {
    let double = fn(x) { x * 2 }
    let result1 = double(5)
    let add10 = make_adder(10)
    let result2 = add10(7)
    let result3 = apply(fn(x) { x * x }, 4)
}
