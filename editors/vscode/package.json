{
  "name": "lace-lang",
  "displayName": "Lace Language",
  "description": "Lace language support — syntax highlighting, diagnostics, hover, snippets",
  "version": "0.2.0",
  "publisher": "lace",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "activationEvents": [
    "onLanguage:lace"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "lace",
        "aliases": [
          "Lace",
          "lace"
        ],
        "extensions": [
          ".lace"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/lace-file.svg",
          "dark": "./icons/lace-file.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "lace",
        "scopeName": "source.lace",
        "path": "./syntaxes/lace.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "lace",
        "path": "./snippets/lace.json"
      }
    ],
    "configuration": {
      "title": "Lace",
      "properties": {
        "lace.lspPath": {
          "type": "string",
          "default": "lace",
          "description": "Path to the lace binary used as the language server. Defaults to 'lace' (must be on PATH)."
        },
        "lace.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Enable error and warning diagnostics from the Lace language server."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.75.0",
    "typescript": "*"
  }
}
